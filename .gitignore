# 10x:generated-gitignore
# 10x internal state (chats, snapshots, settings) — kept local; not
# tracked. The manifest is the single committed marker that lets
# cloned repos identify themselves as 10x projects.
.tenx/*
!.tenx/
!.tenx/manifest.json
tenx/

# Generated chat transcript — rewritten on every assistant turn,
# would create constant commit churn. The canonical chat data
# lives in .tenx/ and is restored from there, so this file is
# purely a human-readable mirror that doesn't belong in history.
conversation.md

# Generated deployment guide — regenerated by 10x and useful
# locally, but noisy in commits.
PRODUCTION.md

# 10x reconciliation metadata
ios/.tenx-source-manifest.json

# Local environment and secret files
.env
.env.local
.env.*.local

# Xcode
ios/DerivedData/
DerivedData/
build/
.build/
.swiftpm/
*.xcodeproj/
**/xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/
*.xcuserdatad/
*.moved-aside
*.xccheckout
*.xcscmblueprint

# macOS
.DS_Store
